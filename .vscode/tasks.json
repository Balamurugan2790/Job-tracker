{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Backend",
			"type": "shell",
			"command": "d:/ASUS/project/.venv/Scripts/python.exe",
			"args": ["backend/app_minimalworking.py"],
			"group": "build",
			"isBackground": true
		},
		{
			"label": "Run Frontend",
			"type": "shell",
			"command": "npx",
			"args": ["serve", "-s", "build", "-l", "3000", "--no-clipboard"],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"isBackground": true
		}
	]
}